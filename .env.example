# Copy to .env and fill in. agent.py auto-loads via python-dotenv.

# Optional: cloud LLM provider (only needed if you run with --provider gemini)
GEMINI_API_KEY=

# Optional: web-search fallback for unknown artists/styles.
# Used by the `web_search_vibe` tool. Get a free key at https://tavily.com/.
# If unset, the agent silently skips web search and relies on its catalog +
# the model's own knowledge.
TAVILY_API_KEY=
