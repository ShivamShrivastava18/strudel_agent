{
  "_meta": {
    "version": "1.0",
    "description": "Curated registry of valid Strudel identifiers, used to validate generated code and ground tool lookups.",
    "source": "https://strudel.cc/learn + https://strudel.cc/workshop"
  },
  "functions": {
    "s": {
      "category": "source",
      "signature": "s(pattern: string|Pattern)",
      "description": "Play a sample by name. Same as sound().",
      "examples": ["s(\"bd sd hh cp\")", "s(\"bd*4\").bank(\"RolandTR909\")"]
    },
    "sound": {
      "category": "source",
      "signature": "sound(pattern: string|Pattern)",
      "description": "Play a sample by name. Alias of s().",
      "examples": ["sound(\"bd sd\")"]
    },
    "n": {
      "category": "source",
      "signature": "n(pattern: number|Pattern)",
      "description": "Sample index inside a sound bank, or scale-degree when combined with .scale().",
      "examples": ["n(\"0 1 2 3\").sound(\"jazz\")", "n(\"0 2 4\").scale(\"C:major\")"]
    },
    "note": {
      "category": "source",
      "signature": "note(pattern: string|number|Pattern)",
      "description": "Play a musical note. Accepts note names (c4, d#3, eb5) or MIDI numbers.",
      "examples": ["note(\"c e g\")", "note(\"<60 62 64>\")"]
    },
    "freq": {
      "category": "source",
      "signature": "freq(pattern: number|Pattern)",
      "description": "Set raw frequency in Hz.",
      "examples": ["freq(\"220 330 440\")"]
    },
    "bank": {
      "category": "source",
      "signature": "bank(name: string)",
      "description": "Select a drum-machine bank for samples.",
      "examples": ["s(\"bd sd\").bank(\"RolandTR909\")"]
    },

    "stack": {
      "category": "factory",
      "signature": "stack(...patterns)",
      "description": "Layer multiple patterns simultaneously.",
      "examples": ["stack(s(\"bd*4\"), s(\"hh*8\"))"]
    },
    "cat": {
      "category": "factory",
      "signature": "cat(...patterns)",
      "description": "Concatenate patterns sequentially across cycles (one pattern per cycle).",
      "examples": ["cat(s(\"bd*4\"), s(\"sd*4\"))"]
    },
    "seq": {
      "category": "factory",
      "signature": "seq(...patterns)",
      "description": "Concatenate patterns sequentially within a single cycle.",
      "examples": ["seq(s(\"bd\"), s(\"hh*2\"))"]
    },
    "arrange": {
      "category": "factory",
      "signature": "arrange(...[cycles, pattern])",
      "description": "Arrange patterns over a fixed number of cycles each.",
      "examples": ["arrange([2, s(\"bd*4\")], [2, s(\"sd*4\")])"]
    },
    "silence": {
      "category": "factory",
      "signature": "silence",
      "description": "An empty pattern.",
      "examples": ["silence"]
    },

    "fast": {
      "category": "time",
      "signature": ".fast(factor: number|Pattern)",
      "description": "Speed up a pattern by factor.",
      "examples": ["s(\"bd sd\").fast(2)"]
    },
    "slow": {
      "category": "time",
      "signature": ".slow(factor: number|Pattern)",
      "description": "Slow a pattern down by factor.",
      "examples": ["s(\"bd sd hh cp\").slow(2)"]
    },
    "hurry": {
      "category": "time",
      "signature": ".hurry(factor)",
      "description": "Like fast() but also pitches samples up.",
      "examples": ["s(\"bd sd\").hurry(2)"]
    },
    "rev": {
      "category": "time",
      "signature": ".rev()",
      "description": "Reverse a pattern.",
      "examples": ["s(\"bd sd hh cp\").rev()"]
    },
    "palindrome": {
      "category": "time",
      "signature": ".palindrome()",
      "description": "Play forward then reverse.",
      "examples": ["s(\"bd sd hh cp\").palindrome()"]
    },
    "iter": {
      "category": "time",
      "signature": ".iter(n)",
      "description": "Rotate the pattern starting position by 1/n each cycle.",
      "examples": ["s(\"bd sd hh cp\").iter(4)"]
    },
    "chunk": {
      "category": "time",
      "signature": ".chunk(n, fn)",
      "description": "Apply fn to one of n equally-sized chunks each cycle.",
      "examples": ["s(\"bd*8\").chunk(4, x => x.fast(2))"]
    },
    "off": {
      "category": "time",
      "signature": ".off(time, fn)",
      "description": "Layer a transformed copy offset by time.",
      "examples": ["note(\"c e g\").off(1/8, x => x.add(7))"]
    },
    "early": {
      "category": "time",
      "signature": ".early(amount)",
      "description": "Shift events earlier in time.",
      "examples": ["s(\"bd*4\").early(1/16)"]
    },
    "late": {
      "category": "time",
      "signature": ".late(amount)",
      "description": "Shift events later in time.",
      "examples": ["s(\"bd*4\").late(1/16)"]
    },
    "ply": {
      "category": "time",
      "signature": ".ply(n)",
      "description": "Repeat each event n times.",
      "examples": ["s(\"bd sd\").ply(2)"]
    },

    "every": {
      "category": "conditional",
      "signature": ".every(n, fn)",
      "description": "Apply fn every n cycles.",
      "examples": ["s(\"bd sd\").every(4, x => x.rev())"]
    },
    "firstOf": {
      "category": "conditional",
      "signature": ".firstOf(n, fn)",
      "description": "Apply fn to the first of every n cycles. Alias of every().",
      "examples": ["s(\"bd sd\").firstOf(4, x => x.fast(2))"]
    },
    "lastOf": {
      "category": "conditional",
      "signature": ".lastOf(n, fn)",
      "description": "Apply fn to the last of every n cycles.",
      "examples": ["s(\"bd sd\").lastOf(4, x => x.rev())"]
    },
    "when": {
      "category": "conditional",
      "signature": ".when(boolPattern, fn)",
      "description": "Apply fn when boolean pattern is true.",
      "examples": []
    },
    "mask": {
      "category": "conditional",
      "signature": ".mask(boolPattern)",
      "description": "Keep events where mask is truthy.",
      "examples": ["s(\"bd*8\").mask(\"1 0 1 1\")"]
    },
    "struct": {
      "category": "conditional",
      "signature": ".struct(boolPattern)",
      "description": "Apply rhythm structure from boolean pattern.",
      "examples": ["note(\"c\").struct(\"1 0 1 1\")"]
    },
    "sometimes": {
      "category": "conditional",
      "signature": ".sometimes(fn)",
      "description": "Apply fn 50% of the time per event.",
      "examples": ["s(\"bd sd\").sometimes(x => x.fast(2))"]
    },
    "sometimesBy": {
      "category": "conditional",
      "signature": ".sometimesBy(prob, fn)",
      "description": "Apply fn with given probability.",
      "examples": ["s(\"bd sd\").sometimesBy(.25, x => x.rev())"]
    },
    "often": {
      "category": "conditional",
      "signature": ".often(fn)",
      "description": "Apply fn ~75% of the time.",
      "examples": []
    },
    "rarely": {
      "category": "conditional",
      "signature": ".rarely(fn)",
      "description": "Apply fn ~25% of the time.",
      "examples": []
    },
    "someCycles": {
      "category": "conditional",
      "signature": ".someCycles(fn)",
      "description": "Apply fn for some entire cycles.",
      "examples": []
    },
    "someCyclesBy": {
      "category": "conditional",
      "signature": ".someCyclesBy(prob, fn)",
      "description": "Apply fn for some cycles with probability.",
      "examples": []
    },
    "degrade": {
      "category": "conditional",
      "signature": ".degrade()",
      "description": "Randomly drop 50% of events.",
      "examples": ["s(\"hh*16\").degrade()"]
    },
    "degradeBy": {
      "category": "conditional",
      "signature": ".degradeBy(prob)",
      "description": "Randomly drop a fraction of events.",
      "examples": ["s(\"hh*16\").degradeBy(.3)"]
    },

    "jux": {
      "category": "stereo",
      "signature": ".jux(fn)",
      "description": "Play original on left channel, fn-transformed copy on right.",
      "examples": ["s(\"bd sd hh cp\").jux(rev)"]
    },
    "juxBy": {
      "category": "stereo",
      "signature": ".juxBy(amount, fn)",
      "description": "Like jux but stereo-spread is controllable.",
      "examples": []
    },
    "superimpose": {
      "category": "stereo",
      "signature": ".superimpose(fn)",
      "description": "Layer original with a transformed copy.",
      "examples": ["note(\"c e g\").superimpose(x => x.add(7))"]
    },
    "layer": {
      "category": "stereo",
      "signature": ".layer(...fns)",
      "description": "Layer multiple transformed copies.",
      "examples": ["note(\"c e g\").layer(x => x, x => x.add(7))"]
    },

    "gain": {
      "category": "amp",
      "signature": ".gain(value: number|Pattern)",
      "description": "Set amplitude (0..1+).",
      "examples": ["s(\"bd*4\").gain(.8)"]
    },
    "velocity": {
      "category": "amp",
      "signature": ".velocity(value)",
      "description": "Set per-event velocity 0..1.",
      "examples": []
    },
    "pan": {
      "category": "amp",
      "signature": ".pan(value)",
      "description": "Stereo pan, 0=left .. 1=right.",
      "examples": ["s(\"bd cp\").pan(\"0 1\")"]
    },

    "lpf": {
      "category": "filter",
      "signature": ".lpf(cutoff: number|Pattern)",
      "description": "Low-pass filter cutoff in Hz.",
      "examples": ["s(\"hh*16\").lpf(\"200 1000 4000\")"],
      "aliases": ["cutoff"]
    },
    "lpq": {
      "category": "filter",
      "signature": ".lpq(q)",
      "description": "Low-pass filter resonance.",
      "examples": ["s(\"hh*16\").lpf(800).lpq(10)"],
      "aliases": ["resonance"]
    },
    "hpf": {
      "category": "filter",
      "signature": ".hpf(cutoff)",
      "description": "High-pass filter cutoff in Hz.",
      "examples": ["s(\"hh*16\").hpf(2000)"],
      "aliases": ["hcutoff"]
    },
    "hpq": {
      "category": "filter",
      "signature": ".hpq(q)",
      "description": "High-pass filter resonance.",
      "examples": [],
      "aliases": ["hresonance"]
    },
    "bpf": {
      "category": "filter",
      "signature": ".bpf(freq)",
      "description": "Band-pass filter frequency.",
      "examples": [],
      "aliases": ["bandf"]
    },
    "bpq": {
      "category": "filter",
      "signature": ".bpq(q)",
      "description": "Band-pass filter Q.",
      "examples": [],
      "aliases": ["bandq"]
    },
    "vowel": {
      "category": "filter",
      "signature": ".vowel(letter)",
      "description": "Apply a vowel formant filter (a/e/i/o/u).",
      "examples": ["note(\"c e g\").s(\"sawtooth\").vowel(\"<a e i o>\")"]
    },

    "attack": {
      "category": "envelope",
      "signature": ".attack(seconds)",
      "description": "Amp envelope attack time.",
      "examples": []
    },
    "decay": {
      "category": "envelope",
      "signature": ".decay(seconds)",
      "description": "Amp envelope decay time.",
      "examples": []
    },
    "sustain": {
      "category": "envelope",
      "signature": ".sustain(level)",
      "description": "Amp envelope sustain level.",
      "examples": []
    },
    "release": {
      "category": "envelope",
      "signature": ".release(seconds)",
      "description": "Amp envelope release time.",
      "examples": []
    },
    "adsr": {
      "category": "envelope",
      "signature": ".adsr(\"a:d:s:r\")",
      "description": "Set amp envelope as colon-separated string.",
      "examples": ["note(\"c e g\").s(\"sawtooth\").adsr(\".01:.2:.4:.5\")"]
    },

    "room": {
      "category": "fx",
      "signature": ".room(amount)",
      "description": "Reverb send amount (0..1+).",
      "examples": ["s(\"bd sd\").room(.5)"]
    },
    "roomsize": {
      "category": "fx",
      "signature": ".roomsize(size)",
      "description": "Reverb room size.",
      "examples": [],
      "aliases": ["size", "rsize"]
    },
    "delay": {
      "category": "fx",
      "signature": ".delay(amount)",
      "description": "Delay send amount.",
      "examples": ["s(\"bd cp\").delay(.5)"]
    },
    "delaytime": {
      "category": "fx",
      "signature": ".delaytime(seconds)",
      "description": "Delay time in seconds (or fraction with mini-notation).",
      "examples": ["s(\"cp\").delay(.7).delaytime(.25)"],
      "aliases": ["dt"]
    },
    "delayfeedback": {
      "category": "fx",
      "signature": ".delayfeedback(amount)",
      "description": "Delay feedback amount.",
      "examples": [],
      "aliases": ["fb", "delayfb"]
    },
    "crush": {
      "category": "fx",
      "signature": ".crush(bits)",
      "description": "Bit-crusher (lower = more crushed).",
      "examples": ["s(\"bd*4\").crush(4)"]
    },
    "coarse": {
      "category": "fx",
      "signature": ".coarse(n)",
      "description": "Sample-rate reducer.",
      "examples": []
    },
    "shape": {
      "category": "fx",
      "signature": ".shape(amount)",
      "description": "Wave-shaper distortion.",
      "examples": []
    },
    "distort": {
      "category": "fx",
      "signature": ".distort(amount)",
      "description": "Distortion.",
      "examples": []
    },
    "phaser": {
      "category": "fx",
      "signature": ".phaser(rate)",
      "description": "Phaser rate in Hz.",
      "examples": []
    },
    "phaserdepth": {
      "category": "fx",
      "signature": ".phaserdepth(d)",
      "description": "Phaser modulation depth (0-1).",
      "examples": []
    },
    "phaserrate": {
      "category": "fx",
      "signature": ".phaserrate(r)",
      "description": "Phaser rate (alias of .phaser()).",
      "examples": []
    },
    "phasersweep": {
      "category": "fx",
      "signature": ".phasersweep(s)",
