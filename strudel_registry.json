    "speed": {
      "category": "fx",
      "signature": ".speed(rate)",
      "description": "Sample playback speed (also pitches).",
      "examples": ["s(\"bd*4\").speed(\"1 2 .5 1\")"]
    },
    "begin": {
      "category": "fx",
      "signature": ".begin(0..1)",
