      "examples": []
    },
    "tremolo": {
      "category": "fx",
      "signature": ".tremolo(rate)",
      "description": "Amplitude tremolo rate.",
      "examples": []
    },
    "vib": {
      "category": "fx",
      "signature": ".vib(rate)",
      "description": "Vibrato rate (alias of vibrato).",
      "examples": ["note(\"a e\").vib(4)"],
      "aliases": ["vibrato"]
    },
    "vibmod": {
      "category": "fx",
      "signature": ".vibmod(depth)",
