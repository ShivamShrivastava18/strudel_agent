  "mini_notation": {
    "*": "repeat: 'bd*4' = bd four times",
    "/": "slow: 'bd/2' = once every 2 cycles",
    "?": "degrade: 'bd?' = 50% chance",
    "!": "replicate: 'bd!3' = bd repeated occupying same time",
    "<>": "alternation across cycles: '<a b c>'",
    "[]": "subgroup: '[bd sd]'",
    ",": "parallel: '[bd, hh*4]'",
    "~": "rest",
    "@": "weight: 'bd@2 sd' = bd is twice as long",
    ":": "select sub-sample: 'bd:2'",
    "(): euclidean": "'bd(3,8)' = euclidean rhythm 3 over 8",
    ".": "alternate notation alias separator"
  },

  "common_pitfalls": [
    "Use s() or sound() for samples, note() for pitched notes — don't mix arbitrarily.",
    "n() inside a sound bank picks sample index; n() with .scale() gives scale degrees.",
    "Filter cutoffs should be in Hz (e.g. 200..8000), not normalized 0..1.",
    "Reverb amount is .room(); 'reverb()' is NOT a Strudel function.",
    "Use .delaytime() and .delayfeedback() (or aliases dt/fb), not 'echo()'.",
    "stack(), cat(), seq() take patterns as arguments separated by commas, not arrays.",
    "Strudel uses method chaining: s(\"bd\").fast(2), not fast(s(\"bd\"), 2).",
    "Mini-notation strings go inside s(), n(), or note(); don't pass plain strings to .gain() etc.",
    "Use .cpm(120/4) to set BPM treating the cycle as one bar of 4 beats.",
    "Random helpers: choose, chooseCycles, wchoose, pick, pickF — NOT 'random()' or 'randomChoice()'."
  ]
}
