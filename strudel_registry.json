    },
    "end": {
      "category": "fx",
      "signature": ".end(0..1)",
      "description": "End position within sample.",
      "examples": []
    },
    "loop": {
      "category": "fx",
      "signature": ".loop(0|1)",
      "description": "Loop the sample.",
      "examples": []
    },
    "cut": {
      "category": "fx",
      "signature": ".cut(group)",
      "description": "Cut group: events in same group cancel each other.",
